{
    "manifest_version": 3,
    "name": "RiMS E-Claim Sync",
    "version": "1.0",
    "description": "ดึงข้อมูลจากระบบ E-Claim สปสช. เข้าสู่ระบบ RiMS สำหรับโรงพยาบาล",
    "permissions": [
        "activeTab",
        "scripting",
        "storage"
    ],
    "host_permissions": [
        "https://eclaim.nhso.go.th/*",
        "<all_urls>"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "RiMS E-Claim Sync"
    }
}